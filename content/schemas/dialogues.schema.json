{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Dialogues batch",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["id", "title", "scenario", "level", "lines"],
    "properties": {
      "id": { "type": "string", "pattern": "^dlg:[0-9]{2}$" },
      "title": { "type": "string", "minLength": 3 },
      "scenario": { "enum": ["classroom", "campus", "daily"] },
      "level": { "enum": ["A2", "B1", "B2"] },
      "lines": {
        "type": "array",
        "minItems": 4,
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["ord", "speaker", "lang", "text"],
          "properties": {
            "ord": { "type": "integer", "minimum": 1 },
            "speaker": { "type": "string", "minLength": 1 },
            "lang": { "enum": ["en", "zh"] },
            "text": { "type": "string", "minLength": 1 },
            "pinyin": { "type": "string", "minLength": 1 },
            "ru_note": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
