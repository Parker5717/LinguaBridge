{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Grammar metalanguage terms batch",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["id", "term", "en_explanation", "ru_translation", "zh_example", "zh_example_pinyin", "zh_example_en"],
    "properties": {
      "id": { "type": "string", "pattern": "^gram:[0-9]{4}$" },
      "term": { "type": "string", "minLength": 2 },
      "en_explanation": { "type": "string", "minLength": 20 },
      "ru_translation": { "type": "string", "minLength": 2 },
      "zh_example": { "type": "string", "minLength": 1 },
      "zh_example_pinyin": { "type": "string", "minLength": 1 },
      "zh_example_en": { "type": "string", "minLength": 3 }
    }
  }
}
