{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HSK 1-2 grammar points batch",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["id", "title", "pattern", "en_explanation", "example_zh", "example_pinyin", "example_en", "ru_note"],
    "properties": {
      "id": { "type": "string", "pattern": "^hskg:[0-9]{4}$" },
      "title": { "type": "string", "minLength": 3 },
      "pattern": { "type": "string", "minLength": 1 },
      "en_explanation": { "type": "string", "minLength": 30 },
      "example_zh": { "type": "string", "minLength": 2 },
      "example_pinyin": { "type": "string", "minLength": 2 },
      "example_en": { "type": "string", "minLength": 3 },
      "ru_note": { "type": "string", "minLength": 3 }
    }
  }
}
