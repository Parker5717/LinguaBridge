{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Vocabulary batch",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "level",
      "headword",
      "ipa",
      "pos",
      "ru_translation",
      "en_definition",
      "example1",
      "example2",
      "topic"
    ],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^vocab:(a2b1|b1b2):[0-9]{4}$"
      },
      "level": {
        "enum": [
          "A2B1",
          "B1B2"
        ]
      },
      "headword": {
        "type": "string",
        "minLength": 1,
        "maxLength": 40
      },
      "ipa": {
        "type": "string",
        "minLength": 2,
        "pattern": "^/.*/$"
      },
      "pos": {
        "enum": [
          "noun",
          "verb",
          "adjective",
          "adverb",
          "preposition",
          "conjunction",
          "pronoun",
          "phrase",
          "phrasal verb",
          "determiner",
          "interjection",
          "numeral"
        ]
      },
      "ru_translation": {
        "type": "string",
        "minLength": 1
      },
      "en_definition": {
        "type": "string",
        "minLength": 10
      },
      "example1": {
        "type": "string",
        "minLength": 10
      },
      "example2": {
        "type": "string",
        "minLength": 10
      },
      "topic": {
        "type": "string",
        "minLength": 2
      },
      "example1_ru": {
        "type": "string",
        "minLength": 5
      }
    }
  }
}